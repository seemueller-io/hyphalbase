{
  "name": "@hyphalbase/seeder",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "bun run barrels && bun build --target=bun src/index.ts --outfile=dist/index.js",
    "barrels": "barrels",
    "start": "bun run barrels && bun --watch src/index.ts",
    "start:prod": "cross-env NODE_ENV=production bun dist/index.js",
    "test": "bun run test:lint&&bun run test:coverage",
    "test:unit": "cross-env NODE_ENV=tesxxt vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@tsed/ajv": "^8.7.1",
    "@tsed/barrels": "^6.2.1",
    "@tsed/cli-core": "6.2.1",
    "@tsed/core": "^8.7.1",
    "@tsed/di": "^8.7.1",
    "@tsed/engines": "^8.7.1",
    "@tsed/exceptions": "^8.7.1",
    "@tsed/json-mapper": "^8.7.1",
    "@tsed/logger": "^7.0.2",
    "@tsed/openspec": "^8.7.1",
    "@tsed/platform-cache": "^8.7.1",
    "@tsed/platform-exceptions": "^8.7.1",
    "@tsed/platform-express": "^8.7.1",
    "@tsed/platform-http": "^8.7.1",
    "@tsed/platform-log-request": "^8.7.1",
    "@tsed/platform-middlewares": "^8.7.1",
    "@tsed/platform-params": "^8.7.1",
    "@tsed/platform-response-filter": "^8.7.1",
    "@tsed/platform-views": "^8.7.1",
    "@tsed/schema": "^8.7.1",
    "ajv": "^8.17.1",
    "body-parser": "^1.20.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.1",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.2",
    "method-override": "^3.0.0",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@swc/core": "^1.11.13",
    "@tsed/cli-plugin-eslint": "6.2.1",
    "@tsed/cli-plugin-vitest": "6.2.1",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/inquirer": "^8.2.4",
    "@types/method-override": "^3.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.13",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^16.0.0",
    "supertest": "^7.1.0",
    "tslib": "^2.8.1",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.9"
  },
  "tsed": {
    "convention": "conv_default",
    "architecture": "arc_default",
